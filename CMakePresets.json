{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },

    "configurePresets": [

        {
            "name": "clang-debug",
            "displayName": "Clang Debug",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/clang-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "C:/Users/user/.utils/llvm-mingw/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "C:/Users/user/.utils/llvm-mingw/bin/clang++.exe",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/clang-debug",
                "Containers_DIR": "E:/Code/C_code/libraries/Containers/install/clang-debug/lib/cmake/Containers",
                "CommonApi_DIR": "E:/Code/C_code/libraries/CommonApi/install/clang-debug/lib/cmake/CommonApi",
                "PlatformKit_DIR": "E:/Code/C_code/libraries/PlatformKit/install/clang-debug/lib/cmake/PlatformKit",
                "GraphicsWrapper_DIR": "E:/Code/C_code/libraries/GraphicsWrapper",
                "Freetype_DIR": "E:/API/freetype-master",
                "harfbuzz_DIR": "E:/API/harfbuzz-main",
                "ICU_ROOT": "E:/API/icu"
            }
        },
        {
