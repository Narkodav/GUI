prefix=E:/Code/C_code/libraries/GUI/install/clang-debug
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: harfbuzz
Description: HarfBuzz text shaping library
Version: 14.2.0

Libs: -L${libdir} -lharfbuzz
Libs.private: -lm -pthread
Requires.private: freetype2 >= 20.0.14
Cflags: -I${includedir}/harfbuzz
