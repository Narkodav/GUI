#shader vertex#version 330 corelayout (location = 0) in vec2 aPos; //from 0 to 1layout (location = 1) in vec2 aTexCoord;uniform mat4 uProjection;   // transforms from NDC to window coordsuniform float uZValue;      // from -1 to 1uniform vec2 uPosition;     // in window pixelsuniform vec2 uSize;         // in window pixelsuniform vec2 uBearing;      // in window pixelsuniform float uScale;       // can be literally anythingout vec2 TexCoord;void main() {              vec2 pos = vec2(uPosition.x + uBearing.x * uScale,         uPosition.y - (uSize.y - uBearing.y) * uScale); //scaled position in pixels    vec2 scaledSize = uSize * uScale;                    //scaled size in pixels    //transforms pixel coords to NDC    gl_Position = uProjection * vec4(aPos * scaledSize + pos, uZValue, 1.0);    TexCoord = aTexCoord;}#shader fragment#version 330 coreout vec4 FragColor;in vec2 TexCoord;uniform sampler2D uTexture;uniform vec4 uColor;void main() {    vec4 texColor = texture(uTexture, TexCoord);    FragColor = uColor * texColor;}